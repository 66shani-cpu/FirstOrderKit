@using FirstOrderKitModel
@model Student
@{
    ViewData["Title"] = "LogIn";
    Layout = null; 
}
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-lime: #8ecf26; /* ירוק דומיננטי לטקסט */
            --border-lime: #adff2f; /* ירוק זוהר למסגרת */
            --bg-light: #f8f9fa; /* רקע לבן שבור */
            --card-white: #ffffff; /* לבן נקי לכרטיס */
            --text-dark: #1a2f23; /* ירוק כהה מאוד לטקסט */
            --input-border: #d1d5db; /* אפור בהיר למסגרות */
        }

        body {
            font-family: 'Assistant', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-dark);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh; /* מרכוז אנכי מושלם */
            /* padding: 20px; */
            padding: 100px 20px 40px 20px; /* משנים את זה כדי שיהיה מרווח מלמעלה */
            box-sizing: border-box;
            position: relative;
        }

        .login-container {
            max-width: 400px; /* צר יותר מהרשמה למראה נקי */
            width: 100%;
            background: var(--card-white);
            border: 3px solid var(--border-lime); /* מסגרת ירוקה זוהרת */
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05), 0 0 15px rgba(173, 255, 47, 0.2);
            text-align: center;
        }

        h2 {
            font-size: 2.2rem;
            font-weight: 800;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dark);
            border-bottom: 2px solid var(--border-lime);
            display: inline-block;
            padding-bottom: 5px;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 20px;
            text-align: right; /* יישור תוויות לימין עבור עברית */
        }

        label {
            font-weight: 700;
            font-size: 0.95rem;
            margin-bottom: -12px;
            margin-right: 5px;
            color: var(--text-dark);
        }

        input {
            background: #ffffff;
            border: 1px solid var(--input-border);
            border-radius: 12px;
            padding: 14px 15px;
            color: var(--text-dark);
            font-size: 1rem;
            transition: all 0.3s ease;
            outline: none;
            width: 100%;
            box-sizing: border-box;
        }

            /* אפקט מיקוד - הופך לירוק זוהר */
            input:focus {
                border-color: var(--neon-lime);
                box-shadow: 0 0 8px rgba(142, 207, 38, 0.2);
                background: #fdfdfd;
            }

        button {
            margin-top: 10px;
            padding: 15px;
            border-radius: 12px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1.1rem;
            border: none;
            background: var(--border-lime);
            color: var(--text-dark);
            box-shadow: 0 4px 10px rgba(173, 255, 47, 0.3);
            text-transform: uppercase;
        }

            button:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(173, 255, 47, 0.4);
                filter: brightness(1.05);
            }

        /* קישור להרשמה (אופציונלי - אם תרצי להוסיף בעתיד) */
        .footer-link {
            margin-top: 25px;
            font-size: 0.9rem;
            color: #6b7280;
        }

            .footer-link a {
                color: var(--neon-lime);
                text-decoration: none;
                font-weight: 700;
            }
        /* עיצוב כפתור החזרה בפינה השמאלית העליונה */
        .btn-back-home {
            position: absolute;
            top: 50px;
            left: 50px;
            text-decoration: none;
            color: var(--text-dark);
            border: 2px solid var(--border-lime);
            padding: 12px 25px;
            border-radius: 50px;
            font-weight: 800;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--card-white);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
            text-transform: uppercase;
            letter-spacing: 1px;
            z-index: 10;
        }

            .btn-back-home:hover {
                background: var(--border-lime);
                transform: translateX(5px); /* זז מעט ימינה בגלל ה-RTL */
                box-shadow: 0 0 20px rgba(173, 255, 47, 0.4);
                color: var(--text-dark);
            }

            .btn-back-home::before {
                content: '←';
                font-size: 1.2rem;
                font-weight: bold;
            }
        /* להדביק כאן, ממש כאן למטה: */
        .error {
            color: #dc2626; /* צבע אדום בולט */
            font-size: 0.85rem;
            margin-top: -15px;
            margin-right: 5px;
            font-weight: 600;
            display: block; /* גורם לשגיאה לרדת שורה בצורה יפה */
    </style>
</head>
<body>

    <div class="login-container">
        <h2>LogIn</h2>
        <a href="http://localhost:5108/guest/ShowUnitsPage" class="btn-back-home">Back to Home</a>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="error" style="text-align: center; margin-bottom: 15px; font-size: 1rem;">
                @ViewBag.ErrorMessage
            </div>
        }
        <form action="http://localhost:5108/Student/LogInStudent" method="post">

@*             <label>Nick Name</label>
            <input type="text" name="StudentNickName" placeholder="Enter your nickname">
            <span asp-validation-for="StudentNickName" class="error"></span>

            <label>Password</label>
            <input type="password" name="password" placeholder="Enter your password">
            <span asp-validation-for="Password" class="error"></span> *@
            <label>Nick Name</label>
            <input asp-for="StudentNickName" type="text" placeholder="Enter your nickname">
            <span asp-validation-for="StudentNickName" class="error"></span>

            <label>Password</label>
            <input asp-for="Password" type="password" placeholder="Enter your password">
            <span asp-validation-for="Password" class="error"></span>

            <button type="submit">Submit</button>
        </form>

        <div class="footer-link">
            Don't have an account? <a href="http://localhost:5108/guest/SignUp">Sign Up</a>
        </div>
    </div>

</body>
</html>