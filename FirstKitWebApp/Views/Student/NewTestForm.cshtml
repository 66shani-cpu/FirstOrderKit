@using FirstOrderKitModel
@model List<TestQuestionViewModel>
@{
    ViewData["Title"] = "NewTestForm";
    Layout = null;
    int count = 0;
}

<style>
    /* עיצוב כללי של הדף - רקע בהיר וכיוון מימין לשמאל */
    body {
        background-color: #f5f5f5;
        color: #000000;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        direction: rtl;
        margin: 0;
        padding: 40px 20px;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        min-height: 100vh;
        box-sizing: border-box;
    }

    /* המכולה המרכזית עם הרקע הלבן והמסגרת הירוקה */
    .container {
        background-color: #ffffff;
        width: 100%;
        max-width: 700px;
        padding: 30px;
        border-radius: 16px;
        border: 2px solid #ADFF2F; /* מסגרת ירוקה זוהרת */
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08); /* צל עדין ורך */
        box-sizing: border-box;
    }

    /* כותרת */
    h1 {
        color: #000000;
        text-align: center;
        font-size: 2.2rem;
        margin-top: 0;
        margin-bottom: 40px;
        font-weight: bold;
    }

    /* עיצוב פסקת השאלה */
    .container p {
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: 25px;
        margin-bottom: 15px;
        color: #000000;
        border-right: 3px solid #ADFF2F; /* פס ירוק קטן בצד השאלה */
        padding-right: 10px;
    }

    /* רשימת התשובות (ul) */
    .container ul {
        list-style: none;
        padding: 0;
        margin: 0 0 30px 0;
    }

    /* שורת תשובה בודדת (li) */
    .container li {
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        background-color: #f9f9f9;
        padding: 12px 15px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        transition: all 0.2s ease;
        cursor: pointer;
        color: #000000;
    }

        /* אפקט מעבר עכבר על שורת תשובה */
        .container li:hover {
            border-color: #ADFF2F;
            background-color: rgba(173, 255, 47, 0.08);
        }

    /* כפתור הרדיו המקורי */
    .container input[type="radio"] {
        margin-left: 12px; /* רווח בין הרדיו לטקסט */
        margin-top: 0;
        cursor: pointer;
        accent-color: #ADFF2F; /* צובע את כפתור הרדיו בירוק */
        transform: scale(1.2); /* מגדיל מעט את כפתור הרדיו */
    }

    /* כפתור שליחה */
    .submit-btn {
        display: block;
        width: 200px;
        margin: 40px auto 0 auto;
        background-color: transparent;
        color: #000000;
        border: 2px solid #ADFF2F;
        padding: 12px 0;
        font-size: 1.1rem;
        font-weight: bold;
        border-radius: 25px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        text-align: center;
    }

        /* אפקט מעבר עכבר על כפתור השליחה */
        .submit-btn:hover {
            background-color: #ADFF2F;
            color: #000000;
            box-shadow: 0 4px 12px rgba(173, 255, 47, 0.4);
            transform: translateY(-2px);
        }

        .submit-btn:active {
            transform: translateY(1px);
        }
</style>

<div class="container">
    <h1>טופס מבחן</h1>

    <form asp-controller="Student" asp-action="SaveTest" method="post">
        <input type="hidden" name="unitId" value="@ViewBag.UnitId" />
        <input type="hidden" name="levelQuestion" value="@ViewBag.Difficulty" />

        @foreach (TestQuestionViewModel testQuestionViewModel in Model)
        {
            count++;
            <p>
                @testQuestionViewModel.Question.QuestionText
            </p>
            <ul>
                @foreach (Answer answer in testQuestionViewModel.QuestionAnswer)
                {
                    string name = "answer" + count;
                    <li>
                        <input type="radio" name="@name" value="@answer.TrueFalse" />
                        @answer.AnswerText
                    </li>
                }
            </ul>
        }
        <button type="submit" class="submit-btn">submit</button>
    </form>
</div>