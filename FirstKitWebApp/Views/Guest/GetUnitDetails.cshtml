@using FirstOrderKitModel
@model Unit
@{
    ViewData["Title"] = "פרטי יחידה - " + Model.UnitName;
//     Layout = "~/Views/Shared/MasterPage.cshtml";
    Layout = null;
}

<link href="~/styles/unitdetails.css" rel="stylesheet" />

<style>
    :root {
        --neon-lime: #adff2f;
        --dark-bg: #1a2f23;
        --card-bg: rgba(255, 255, 255, 0.05);
        --text-white: #ffffff;
    }

    body {
        background-color: var(--dark-bg);
        color: var(--text-white);
        font-family: 'Assistant', sans-serif;
        margin: 0;
    }

    .main-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
        padding: 40px 20px;
        text-align: center;
    }

    /* תיבת התמונה עם אפקט זוהר */
    .image-box {
        position: relative;
        margin-bottom: 40px;
    }

        .image-box img {
            width: 220px;
            height: 220px;
            border-radius: 30px;
            object-fit: cover;
            border: 3px solid var(--neon-lime);
            box-shadow: 0 0 30px rgba(173, 255, 47, 0.3); /* הילה ירוקה מסביב לתמונה */
            transition: transform 0.3s ease;
        }

        .image-box:hover img {
            transform: scale(1.05);
            box-shadow: 0 0 50px rgba(173, 255, 47, 0.5);
        }

    /* עיצוב כותרת היחידה (הוספתי כדי שיהיה ברור על מה מסתכלים) */
    .unit-title {
        font-size: 2.5rem;
        font-weight: 900;
        color: var(--neon-lime);
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    /* תיבת הטקסט / הציטוט */
    .text-box {
        background: var(--card-bg);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(173, 255, 47, 0.2);
        padding: 30px 50px;
        border-radius: 20px;
        max-width: 600px;
        position: relative;
    }

        /* קישוט של גרשיים בשביל הציטוט */
        .text-box::before {
            content: '"';
            position: absolute;
            top: -10px;
            right: 20px;
            font-size: 4rem;
            color: var(--neon-lime);
            opacity: 0.5;
            font-family: serif;
        }

        .text-box p {
            font-size: 1.5rem;
            line-height: 1.6;
            margin: 0;
            font-weight: 600;
            color: var(--text-white);
            font-style: italic;
        }

    /* כפתור חזרה (אופציונלי אבל מומלץ) */
    .back-btn {
        margin-top: 40px;
        text-decoration: none;
        color: var(--text-white);
        font-size: 1rem;
        opacity: 0.7;
        transition: 0.3s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .back-btn:hover {
            opacity: 1;
            color: var(--neon-lime);
        }
</style>

<div class="main-container">

    <div class="image-box">
        <img src="http://localhost:5239/Images/Units/@Model.UnitPicture" alt="@Model.UnitName">
    </div>

    <h1 class="unit-title">@Model.UnitName</h1>

    <div class="text-box">
        <p>
            "הצלחה זה אוסף של צעדים קטנים"
        </p>
    </div>

    @* כפתור חזרה לעמוד הראשי של היחידות *@
    <a href="javascript:history.back()" class="back-btn">
        <span>← חזרה לרשימת היחידות</span>
    </a>

</div>