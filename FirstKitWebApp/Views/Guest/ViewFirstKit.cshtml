@using FirstOrderKitModel
@model OrderFirstKitViewModel

@{
    ViewData["Title"] = "יחידות בצה\"ל";
    Layout = "~/Views/Shared/MasterPage.cshtml"; // ודאי שזה השם המדויק של המאסטר פייג' שלך
}

<style>
    :root {
        --neon-lime: #adff2f;
        --dark-bg: #1a2f23;
        --card-bg: rgba(255, 255, 255, 0.05);
        --text-white: #ffffff;
    }

    /* הקונטיינר הראשי - ללא מסגרות לבנות */
    .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    /* סידור היחידות בשלשות */
    .units {
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* 3 יחידות בשורה */
        gap: 50px; /* רווח נעים בין היחידות */
        justify-items: center;
        margin-top: 30px;
    }

    /* עיצוב הכרטיס */
    .unit {
        background: var(--card-bg);
        border: 1px solid rgba(173, 255, 47, 0.15);
        border-radius: 24px;
        padding: 35px 20px;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        width: 240px;
        backdrop-filter: blur(8px);
    }

        .unit:hover {
            transform: translateY(-12px);
            border-color: var(--neon-lime);
            box-shadow: 0 15px 35px rgba(173, 255, 47, 0.15);
            background: rgba(173, 255, 47, 0.04);
        }

        /* עיצוב התמונה בתוך הכרטיס */
        .unit img {
            width: 130px;
            height: 130px;
            border-radius: 20px;
            object-fit: cover;
            margin-bottom: 25px;
            border: 2px solid transparent;
            transition: border-color 0.3s ease;
        }

        .unit:hover img {
            border-color: var(--neon-lime);
        }

        /* שם היחידה */
        .unit p {
            margin: 0;
            font-weight: 800;
            color: var(--text-white);
            font-size: 1.4rem;
            letter-spacing: 1px;
        }

    /* עיצוב כפתור ההרשמה בראש העמוד */
    .signup-container {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 20px;
    }

    .signup {
        text-decoration: none;
        color: var(--neon-lime);
        border: 2px solid var(--neon-lime);
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: bold;
        transition: all 0.3s ease;
        text-transform: uppercase;
    }

        .signup:hover {
            background: var(--neon-lime);
            color: var(--dark-bg);
            box-shadow: 0 0 20px rgba(173, 255, 47, 0.4);
        }

    hr {
        border: 0;
        border-top: 1px solid rgba(173, 255, 47, 0.1);
        margin-bottom: 50px;
    }

  
</style>

<div class="container">
    <div class="signup-container">
        <a href="http://localhost:5108/guest/SignUp" class="signup">Sign up</a>
    </div>

    <hr>

    <section class="units">
        @foreach (var unit in Model.Units)
        {
            <div class="unit">
                <a href="http://localhost:5108/guest/GetUnitDetails/?unitId=@unit.UnitId">
                    <img src="http://localhost:5239/Images/Units/@unit.UnitPicture" alt="@unit.UnitName">
                </a>
                <p>@unit.UnitName</p>
            </div>
        }
    </section>
</div>