@using FirstOrderKitModel
@model OrderFirstKitViewModel

@{
    ViewData["Title"] = "יחידות בצה\"ל";
    Layout = "~/Views/Shared/MasterPage.cshtml";
}

<style>
    :root {
        --neon-lime: #adff2f;
        --dark-bg: #1a2f23;
        --card-bg: rgba(255, 255, 255, 0.05);
        --text-white: #ffffff;
    }

    .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    /* הקונטיינר של הכפתורים בראש הדף */
    .top-actions-container {
        display: flex;
        justify-content: flex-end; /* מצמיד את הכפתורים לשמאל בגלל ה-RTL */
        gap: 30px; /* המרחב הגדול שביקשת בין הכפתורים */
        margin-bottom: 25px;
        align-items: center;
    }

    /* עיצוב הכפתורים - זהה להרשמה */
    .btn-neon {
        text-decoration: none;
        color: var(--neon-lime);
        border: 2px solid var(--neon-lime);
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 800;
        transition: all 0.3s ease;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
        display: inline-block;
    }

        .btn-neon:hover {
            background: var(--neon-lime);
            color: var(--dark-bg);
            box-shadow: 0 0 25px rgba(173, 255, 47, 0.5);
            transform: translateY(-2px);
        }

    .units {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 50px;
        justify-items: center;
        margin-top: 30px;
    }

    .unit {
        background: var(--card-bg);
        border: 1px solid rgba(173, 255, 47, 0.15);
        border-radius: 24px;
        padding: 35px 20px;
        text-align: center;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        width: 240px;
        backdrop-filter: blur(8px);
    }

        .unit:hover {
            transform: translateY(-12px);
            border-color: var(--neon-lime);
            box-shadow: 0 15px 35px rgba(173, 255, 47, 0.15);
            background: rgba(173, 255, 47, 0.04);
        }

        .unit img {
            width: 130px;
            height: 130px;
            border-radius: 20px;
            object-fit: cover;
            margin-bottom: 25px;
            border: 2px solid transparent;
            transition: border-color 0.3s ease;
        }

        .unit:hover img {
            border-color: var(--neon-lime);
        }

        .unit p {
            margin: 0;
            font-weight: 800;
            color: var(--text-white);
            font-size: 1.4rem;
        }

    hr {
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 50px;
    }
</style>

<div class="container">
    <div class="top-actions-container">
        @* הכפתור החדש - ממוקם משמאל להרשמה עם מרווח גדול *@
        <a href="http://localhost:5108/guest/SampleTests" class="btn-neon">Sample Tests</a>

        @* כפתור ההרשמה *@
         <a href="http://localhost:5108/guest/SignUp" class="btn-neon">Sign up</a>
    </div>

    <hr>

    <section class="units">
        @foreach (var unit in Model.Units)
        {
            <div class="unit">            
                    <img src="http://localhost:5239/Images/Units/@unit.UnitPicture" alt="@unit.UnitName">
                <p>@unit.UnitName</p>
            </div>
        }
    </section>
</div>