@using FirstOrderKitModel
@model RegistationViewModel
@{
    ViewData["Title"] = "Registration";
    Layout = null;
}

<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@400;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-lime: #8ecf26; /* ירוק דומיננטי יותר לטקסט על לבן */
            --border-lime: #adff2f; /* ירוק זוהר למסגרת */
            --bg-white: #f8f9fa; /* לבן "שבור" נעים לעין */
            --card-white: #ffffff; /* לבן נקי לטופס */
            --text-dark: #1a2f23; /* ירוק כהה מאוד במקום שחור מוחלט */
            --input-border: #d1d5db; /* אפור בהיר למסגרות שדות */
            --error-red: #dc2626;
        }

        body {
            font-family: 'Assistant', sans-serif;
            background-color: var(--bg-white);
            color: var(--text-dark);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 40px 20px;
        }

        .form-container {
            max-width: 500px;
            width: 100%;
            background: var(--card-white);
            /* מסגרת ירוקה זוהרת על הרקע הלבן */
            border: 3px solid var(--border-lime);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05), 0 0 15px rgba(173, 255, 47, 0.2);
        }

        h1 {
            text-align: center;
            color: var(--text-dark);
            font-weight: 800;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 2px solid var(--border-lime);
            display: inline-block;
            width: 100%;
            padding-bottom: 10px;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        label {
            font-weight: 700;
            color: var(--text-dark);
            font-size: 0.95rem;
            margin-bottom: -5px;
        }

        input, select {
            background: #ffffff;
            border: 1px solid var(--input-border);
            border-radius: 12px;
            padding: 12px 15px;
            color: var(--text-dark);
            font-size: 1rem;
            transition: all 0.3s ease;
            outline: none;
            width: 100%;
            box-sizing: border-box;
        }

            /* מיקוד שדה - הופך לירוק זוהר */
            input:focus, select:focus {
                border-color: var(--neon-lime);
                box-shadow: 0 0 8px rgba(142, 207, 38, 0.2);
                background: #fdfdfd;
            }

        .error {
            color: var(--error-red);
            font-size: 0.85rem;
            margin-top: -10px;
            font-weight: 600;
        }

        .buttons {
            display: flex;
            gap: 15px;
            margin-top: 25px;
        }

        button {
            flex: 1;
            padding: 14px;
            border-radius: 12px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1rem;
            border: none;
        }

        /* כפתור אישור - ירוק זוהר עם טקסט כהה */
        .btn-submit {
            background: var(--border-lime);
            color: var(--text-dark);
            box-shadow: 0 4px 10px rgba(173, 255, 47, 0.3);
        }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(173, 255, 47, 0.4);
                filter: brightness(1.05);
            }

        /* כפתור איפוס - אפור בהיר */
        .btn-reset {
            background: #f3f4f6;
            color: #6b7280;
            border: 1px solid #e5e7eb;
        }

            .btn-reset:hover {
                background: #e5e7eb;
                color: var(--text-dark);
            }

        /* עיצוב ה-Select כדי שייראה טוב על לבן */
        select {
            cursor: pointer;
            appearance: none; /* מסיר את החץ המובנה של הדפדפן */
            background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
            background-repeat: no-repeat;
            background-position: left 15px center;
            background-size: 15px;
        }
    </style>
</head>
<body>

    <div class="form-container">
        <h1>Registration</h1>

        @if (ViewBag.Error != null)
        {
            <p class="error" style="text-align:center;">There was an error. Come back later!</p>
        }

        <form asp-controller="guest" asp-action="Registration" enctype="multipart/form-data">

            <label>First Name</label>
            <input asp-for="student.StudentFirstName" type="text" placeholder="Enter first name">
            <span asp-validation-for="student.StudentFirstName" class="error"></span>

            <label>Last Name</label>
            <input asp-for="student.StudentLastName" type="text" placeholder="Enter last name">
            <span asp-validation-for="student.StudentLastName" class="error"></span>

            <label>Nickname</label>
            <input asp-for="student.StudentNickName" type="text" placeholder="Choose your nickname">
            <span asp-validation-for="student.StudentNickName" class="error"></span>

            <label>City</label>
            <select asp-for="student.CityId">
                <option value="">Select City</option>
                @foreach (City city in Model.cities)
                {
                    <option value="@city.CityId">@city.CityName</option>
                }
            </select>
            <span asp-validation-for="student.CityId" class="error"></span>

            <label>Unit</label>
            <input asp-for="student.UnitId" type="text" placeholder="Enter Target Unit Name/ID">
            <span asp-validation-for="student.UnitId" class="error"></span>

            <label>Telephone</label>
            <input asp-for="student.StudentTelephone" type="text" placeholder="05X-XXXXXXX">
            <span asp-validation-for="student.StudentTelephone" class="error"></span>

            <label>Address</label>
            <input asp-for="student.StudentAdrres" type="text" placeholder="Street and House Number">
            <span asp-validation-for="student.StudentAdrres" class="error"></span>

            <label>Profile Picture</label>
            <input type="file" name="formFile" id="readerFile" onchange="getFileName()" />
            <input asp-for="student.StudentImage" type="hidden" id="readerImg" />
            <span asp-validation-for="student.StudentImage" class="error"></span>

            @* שדות נסתרים נחוצים *@
            <input asp-for="student.StudentId"  value="15" />
            <input asp-for="student.StudentSalt" type="hidden" value="0" />
            <input asp-for="student.Password"  value="123456" />

            <div class="buttons">
                <button type="reset" class="btn-reset">Restart</button>
                <button type="submit" class="btn-submit">Post</button>
            </div>
        </form>
    </div>

    <script>
        function getFileName() {
            var fullPath = document.getElementById('readerFile').value;
            if (fullPath) {
                var fn = document.getElementById('readerImg');
                fn.value = "." + fullPath.split('.').pop();
            }
        }
    </script>

</body>
</html>