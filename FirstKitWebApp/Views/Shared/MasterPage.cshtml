<style>
    :root {
        /* ירוק בהיר מאוד ושקוף לסרגל הניווט */
        --nav-bg: rgba(45, 90, 65, 0.85);
        /* ירוק ליים בהיר ובולט להדגשות ולוגו */
        --neon-green: #adff2f;
        /* לבן נקי לטקסט */
        --text-white: #ffffff;
    }

    body {
        margin: 0;
        padding-top: 80px;
        /* שיניתי לירוק כהה "רך" יותר כדי שהירוק הבהיר יקפוץ לעין */
        background-color: #1e3a2b;
    }

    .header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 70px;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        display: flex;
        align-items: center;
        padding: 0 5%;
        /* גבול תחתון בירוק בהיר */
        border-bottom: 2px solid rgba(173, 255, 47, 0.3);
        z-index: 1000;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    }

    .meitavtest {
        /* הלוגו עכשיו בירוק ליים בהיר מאוד */
        color: var(--neon-green);
        font-family: 'Assistant', sans-serif;
        font-weight: 800;
        font-size: 1.6rem;
        margin: 0;
        position: absolute; /* מוציא את הכותרת מהזרימה הרגילה */
        left: 50%; /* מזיז אותה לאמצע המסך */
        transform: translateX(-50%); /* מקזז את הרוחב של עצמה כדי שזה יהיה אמצע מדויק */
        margin-left: auto;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        text-shadow: 0 0 10px rgba(173, 255, 47, 0.4);
    }

    .nav-links {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .header a {
        text-decoration: none;
        color: var(--text-white);
        font-weight: 600;
        font-size: 1.05rem;
        transition: all 0.3s ease;
        padding: 8px 15px;
        border-radius: 8px;
    }

        .header a:hover {
            /* ריחוף בצבע ירוק בהיר */
            color: var(--neon-green);
            background: rgba(173, 255, 47, 0.15);
        }

    .login-link {
        /* מסגרת בולטת בירוק בהיר */
        border: 2px solid var(--neon-green);
        color: var(--neon-green) !important;
    }

        .login-link:hover {
            /* בתוך הכפתור יהיה ירוק בהיר והטקסט יהיה כהה לקריאות */
            background: var(--neon-green) !important;
            color: #1e3a2b !important;
            box-shadow: 0 0 15px rgba(173, 255, 47, 0.5);
        }
</style>

<header class="header">
    <h1 class="meitavtest">Meitav Test</h1>
    <nav class="nav-links">
        <a href="http://localhost:5108/Student/ViewAbout" class="about">About</a>
        <a href="http://localhost:5108/Guest/GetTest" class="tests-link">Tests</a>
        <a href="http://localhost:5108/Student/ViewLoginForm" class="login-link">Log in</a>
    </nav>
</header>

<main>
    @RenderBody()
</main>



