<Window x:Class="ManagerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow"
        Height="668"
        Width="1250"
        ResizeMode="NoResize">
    <Window.Resources>
        <FontFamily x:Key="MainFont">/Font/#Special Elite</FontFamily>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="30"></Setter>
            <Setter Property="Margin" Value="10"></Setter>
            <Setter Property="Padding" Value="10"></Setter>
            <Setter Property="Foreground" Value="Red"></Setter>
            <Setter Property="FontFamily" Value="{StaticResource MainFont}"></Setter>
        </Style>

    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition ></RowDefinition>
        </Grid.RowDefinitions>
        <Border Background="#000000">
            <StackPanel Orientation="Vertical" Margin="20" >
                <Image Source="/Images/logo.png" 
                       Height="100"
                       Width="200"
                       Margin="0,0,0,10">

                </Image>

                <Border BorderThickness="2"  BorderBrush="White" Margin="0,10,0,1"></Border>
                <Border BorderThickness="2"  BorderBrush="White" Margin="0,3,0,20"></Border>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/Home1.png"
                           Width="32"></Image>
                    <TextBlock Padding="10">
         <Hyperlink Foreground="White"
                    x:Name="hyperlinkStartPage"
                    Click="hyperlinkStartPage_Click"
                    FontFamily="{StaticResource MainFont}"
                    TextDecorations="None"
                    FontSize="25">Home</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/Update1.png" Width="32"></Image>
                    <TextBlock Padding="10">
                       <Hyperlink x:Name="hyperlinkUpdate"
                                  Foreground="White"
                                  FontFamily="{StaticResource MainFont}"
                                  TextDecorations="None"
                                   FontSize="25"
                                  Click="hyperlinkUpdate_Click">Update</Hyperlink>

                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/Reports2.png" Width="32"></Image>
                    <TextBlock Padding="10">
        <Hyperlink x:Name="hyperlinkReports"
                    Foreground="White"
                   FontFamily="{StaticResource MainFont}"
                   TextDecorations="None"
                   FontSize="25"
                  Click="hyperlinkReports_Click">Report</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/Question1.png" Width="32"></Image>
                    <TextBlock Padding="10">
          <Hyperlink x:Name="hyperlinkQuestion"
                  Foreground="White"
                   FontFamily="{StaticResource MainFont}"
                   TextDecorations="None"
                    FontSize="25"
                    Click="hyperlinkQuestion_Click">Question</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/Students2.png" Width="32"></Image>
                    <TextBlock Padding="10">
       <Hyperlink x:Name="hyperlinkStudent"
                   Foreground="White"
                   FontFamily="{StaticResource MainFont}"
                   TextDecorations="None"
                   FontSize="25"
                    Click="hyperlinkStudent_Click">Student</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/UnitSubject1.png" Width="32"></Image>
                    <TextBlock Padding="10">
        <Hyperlink x:Name="hyperlinkUnit_Subject"
                   Foreground="White"
                   FontFamily="{StaticResource MainFont}"
                   TextDecorations="None"
                                      FontSize="25"
Click="hyperlinkUnit_Subject_Click">Unit</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/LogIn1.png" Width="32"></Image>
                    <TextBlock Padding="10">
<Hyperlink Foreground="White" x:Name="hyperlinkLogin"
           
           FontFamily="{StaticResource MainFont}"
           TextDecorations="None"
           FontSize="25"
           Click="hyperlinkLogin_Click">Login</Hyperlink>
                    </TextBlock>
                </StackPanel>
                <Border BorderThickness="2"  BorderBrush="White" Margin="0,20,0,1"></Border>
                <Border BorderThickness="2"  BorderBrush="White" Margin="0,3,0,20"></Border>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Images/Exit1.png" Width="32"></Image>
                    <TextBlock Padding="10">
<Hyperlink Foreground="Red"
           FontFamily="{StaticResource MainFont}"
           TextDecorations="None"
                              FontSize="25"
Click="hyperlinkExit_Click">Exit</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
        <Frame x:Name="frameMain"  NavigationUIVisibility="Hidden" Grid.Column="1" />

    </Grid>
</Window>