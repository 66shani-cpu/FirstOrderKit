<Window x:Class="ManagerApp.Windows.InactiveUnitsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ManagerApp"
        Title="Inactive Units Archive" Height="550" Width="700"
        WindowStartupLocation="CenterOwner" Background="#F5F5F5">
    <Window.Resources>
        <FontFamily x:Key="SpecialElite">/Fonts/#Special Elite</FontFamily>
        <Style TargetType="{x:Type Button}" x:Key="ImageButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <conv:URIConvertor x:Key="urlConvertor"></conv:URIConvertor>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListView x:Name="ListViewInactiveUnits" Grid.Row="0" Margin="15,20,15,10">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="DarkRed" BorderThickness="1.5" Height="83" CornerRadius="4" Background="#FFF0F0" Width="640">
                        <Canvas Width="620">
                            <Image Source="{Binding UnitPicture, Converter={StaticResource urlConvertor}}" 
                                   Width="50" Height="68" Canvas.Left="10" Canvas.Top="5"/>

                            <Label Content="{Binding UnitName}" 
                                   Canvas.Left="77" Canvas.Top="16" Width="400"
                                   FontSize="30" FontFamily="{StaticResource SpecialElite}" 
                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                   Validation.ErrorTemplate="{x:Null}"/>

                            <Button x:Name="btnRestore" 
                                    Canvas.Left="560" Canvas.Top="25" Width="32" Height="32"
                                    Style="{StaticResource ImageButtonStyle}" Click="btnRestore_Click">
                                <Image Source="/Images/Update1.png" ToolTip="Restore Unit" />
                            </Button>
                        </Canvas>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Content="Close Archive" Grid.Row="1" Width="150" Height="35" Margin="0,10,0,15"
                Background="Gray" Foreground="White" FontSize="16" FontFamily="{StaticResource SpecialElite}" Click="btnClose_Click"/>
    </Grid>
</Window>
