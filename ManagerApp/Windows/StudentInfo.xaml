
<Window x:Class="ManagerApp.Windows.StudentInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ManagerApp.Windows"
        mc:Ignorable="d"
        Title="Student Info" Height="420" Width="600" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.Resources>
        <FontFamily x:Key="SpecialElite">/Fonts/#Special Elite</FontFamily>
    </Window.Resources>

    <Grid Margin="25,20,25,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" 
                   Text="First name:" 
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Foreground="#FF333333"/>
        <TextBlock Grid.Row="0" Grid.Column="1" 
                   Text="{Binding StudentFirstName}"
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Padding="5,0,0,0"/>

        <TextBlock Grid.Row="1" Grid.Column="0" 
                   Text="Last name:" 
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Foreground="#FF333333"/>
        <TextBlock Grid.Row="1" Grid.Column="1" 
                   Text="{Binding StudentLastName}"
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Padding="5,0,0,0"/>

        <TextBlock Grid.Row="2" Grid.Column="0" 
                   Text="City:" 
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Foreground="#FF333333"/>
        <TextBlock Grid.Row="2" Grid.Column="1" 
                   Text="{Binding CityName}"
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Padding="5,0,0,0"/>

        <TextBlock Grid.Row="3" Grid.Column="0" 
                   Text="Telephone:" 
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Foreground="#FF333333"/>
        <TextBlock Grid.Row="3" Grid.Column="1" 
                   Text="{Binding StudentTelephone}"
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Padding="5,0,0,0"/>

        <TextBlock Grid.Row="4" Grid.Column="0" 
                   Text="Address:" 
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Foreground="#FF333333"/>
        <TextBlock Grid.Row="4" Grid.Column="1" 
                   Text="{Binding StudentAdrres}"
                   FontSize="18" 
                   FontFamily="{StaticResource SpecialElite}"
                   VerticalAlignment="Center" 
                   Padding="5,0,0,0"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom">

            <Button Content="Close" 
                    Width="140" 
                    Height="42" 
                    FontSize="18" 
                    FontFamily="{StaticResource SpecialElite}"
                    Click="Button_Click"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>

