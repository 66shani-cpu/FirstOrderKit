<Window x:Class="ManagerApp.Windows.InactiveQuestionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inactive Questions Archive" Height="550" Width="700"
        WindowStartupLocation="CenterOwner" Background="#F5F5F5">
    <Window.Resources>
        <FontFamily x:Key="SpecialElite">/Fonts/#Special Elite</FontFamily>
        <Style TargetType="{x:Type Button}" x:Key="ImageButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListView x:Name="ListViewInactiveQuestions" 
                  Grid.Row="0"
                  HorizontalAlignment="Stretch"
                  Margin="15,20,15,10">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="DarkRed"
                            BorderThickness="1.5" 
                            Height="85"
                            CornerRadius="4"
                            Background="#FFF0F0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Image Source="/Images/QuestionImage.png"
                                   Width="50"
                                   Height="68"
                                   Margin="15,0,15,0"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"/>

                            <TextBlock x:Name="QuestionText"
                                       Grid.Column="1"
                                       Text="{Binding QuestionText}"
                                       TextWrapping="Wrap"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       FontSize="17" 
                                       FontFamily="{StaticResource SpecialElite}"
                                       Validation.ErrorTemplate="{x:Null}"/>

                            <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,15,0">
                                <Button x:Name="btnRestore"
                                        Width="32"
                                        Height="32"
                                        Style="{StaticResource ImageButtonStyle}"
                                        Click="btnRestore_Click">
                                    <Image Source="/Images/Update1.png" x:Name="imgRestore" ToolTip="שחזר שאלה לפעילה" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button x:Name="btnClose"
                Grid.Row="1"
                Content="Close Archive"
                Width="150"
                Height="35"
                Margin="0,10,0,15"
                Background="Gray"
                Foreground="White"
                FontSize="16"
                FontFamily="{StaticResource SpecialElite}"
                Click="btnClose_Click"/>
    </Grid>
</Window>