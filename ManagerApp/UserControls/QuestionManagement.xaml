<UserControl x:Class="ManagerApp.UserControls.QuestionManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManagerApp.UserControls"
             xmlns:conv="clr-namespace:ManagerApp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <FontFamily x:Key="SpecialElite">/Fonts/#Special Elite</FontFamily>
        <Style TargetType="{x:Type Button}" x:Key="ImageButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>
    <Canvas>
        <ListView x:Name="ListViewQuestion" Height="500"
                  Width="920"
                  Canvas.Top="30"
                  Canvas.Left="26"
                  >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"
               
               BorderThickness="1" 
               Height="83" 
               Canvas.Left="23" 
               Canvas.Top="21"
               Width="675">
                        <Canvas Width="700"
               Margin="0,0,0,23">
                            <Image Source="/Images/QuestionImage.png"
                x:Name="imageBook"
                      Width="50"
                      Height="68"
                      Canvas.Left="10"
                      Canvas.Top="5"/>

                            <!--<Button x:Name="btnInfo"
                        Height="32" 
                        Canvas.Left="540" 
                        Canvas.Top="25"
                        Width="32"
                        Style="{StaticResource ImageButtonStyle}">
                    <Image Source="/Images/infoicon.png"/>
                </Button>-->
                            <Button x:Name="btnEdit"
                    Canvas.Left="585"
                    Canvas.Top="25"
                    Width="32"
                    Style="{StaticResource ImageButtonStyle}" 
                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Image Source="/Images/UpdateQuestion.png" />
                            </Button>
                            <Button x:Name="btnDelete"
                         Canvas.Left="630"
                         Canvas.Top="25"
                         Width="32"
                         Style="{StaticResource ImageButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Image Source="/Images/UpdateDelete.png" />
                            </Button>
                            <Label x:Name="labelBookTitele"
                      Content="{Binding QuestionText}"
                      Canvas.Left="77"
                      Canvas.Top="22"
                      Width="450"
                      FontSize="17" 
                      FontFamily="{StaticResource SpecialElite}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Canvas>

                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBox x:Name="textBoxQuestionText"
                 Canvas.Left="236" 
                 TextWrapping="Wrap" 
                 Text="{Binding Book.BookName, UpdateSourceTrigger=PropertyChanged}"
                 Canvas.Top="49"
                 Padding="7"
                 Width="332"
                 />
        <TextBox x:Name="textBoxLevelQuestions" 
                 Padding="7"
                 AcceptsReturn="True" 
                 Canvas.Left="238"
                 TextWrapping="Wrap"
                 Canvas.Top="117"
                 Width="334"
                 HorizontalAlignment="Left" 
                 VerticalAlignment="Top"
                 Height="68"/>
        <Button x:Name="buttonAddNewBook"
          Canvas.Left="268" 
          Canvas.Top="490" 
          Width="254" 
          Height="47"
          FontSize="20"
          FontFamily="{StaticResource SpecialElite}"
          Foreground="White"
          Background="Navy"
                Click="buttonAddNewQuestion_Click">
            <Button.Content>
                <StackPanel Orientation="Horizontal">
                    <Image Width="32" Source="/Images/AddQuestion.png"></Image>
                    <Label Foreground="White"
                     Padding="15,7,0,0"
                     Content="Add new Question"
                     FontSize="20"></Label>
                </StackPanel>
            </Button.Content>
        </Button>
        
    </Canvas>
</UserControl>
