<UserControl x:Class="ManagerApp.UserControls.Student"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManagerApp.UserControls"
             xmlns:conv="clr-namespace:ManagerApp"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <FontFamily x:Key="SpecialElite">/Fonts/#Special Elite</FontFamily>
        <Style TargetType="{x:Type Button}" x:Key="ImageButtonStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <conv:URIConverter x:Key="urlConverter"></conv:URIConverter>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch">
        <ListView x:Name="ListViewStudent"  
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch"
                  Margin="20,20,20,20">

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"
                            BorderThickness="1" 
                            Height="95">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Image Source="{Binding StudentImage, Converter={StaticResource urlConverter}}"
                                   x:Name="imageBook"
                                   Width="55"
                                   Height="68"
                                   Margin="30,0,15,0"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center" Margin="25,0,0,0">

                                <Label x:Name="studentFirstName"
                                       Content="{Binding StudentFirstName}"
                                       FontSize="30" 
                                       FontFamily="{StaticResource SpecialElite}" 
                                       HorizontalAlignment="Left" 
                                       VerticalAlignment="Center"
                                       Padding="0,0,30,0"/>
                                <Label x:Name="studentLastName"
                                       Content="{Binding StudentLastName}"
                                       FontSize="30" 
                                       FontFamily="{StaticResource SpecialElite}" 
                                       HorizontalAlignment="Left" 
                                       VerticalAlignment="Center"
                                       Padding="0"/>

                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0">

                                <Button x:Name="btnInfo"
                                        Tag="{Binding StudentId}"
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,20,0"
                                        Cursor="Hand"
                                        Style="{StaticResource ImageButtonStyle}" 
                                        Click="btnInfo_Click">
                                    <Image Source="/Images/Information.png"/>
                                </Button>

                                <Button x:Name="btnDelete"
                                        Width="32"
                                        Height="32"
                                        Style="{StaticResource ImageButtonStyle}"
                                        Click="btnDelete_Click">
                                    <Image Source="/Images/UpdateDelete.png" />
                                </Button>

                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>