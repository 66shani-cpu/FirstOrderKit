<UserControl x:Class="ManagerApp.UserControls.UnitReportUserControl"
             
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vms="clr-namespace:FirstOrderKitModel.ViewModel;assembly=FirstOrderKitModel">
    <UserControl.DataContext>
        <vms:UnitBarData/>
    </UserControl.DataContext>
    <lvc:CartesianChart LegendPosition="Right">

        <lvc:CartesianChart.Series>
            <lvc:SeriesCollection>
                <lvc:XamlColumnSeries SeriesName="Passed" Values="{Binding Pass}"/>
                <lvc:XamlColumnSeries SeriesName="Faield" Values="{Binding NotPass}"/>
            </lvc:SeriesCollection>
        </lvc:CartesianChart.Series>

        <!-- We use force to min step to show all the labels always. -->

        <lvc:CartesianChart.XAxes>
            <lvc:AxesCollection>
                <lvc:XamlAxis
                    Labels="{Binding Labels}"
                    AxisName="units dgfdfdv  drdf"
                    LabelsAlignment="Start"
                   LabelsRotation="45"
                    LabelsDensity="0"
                    SeparatorsPaint="#c8c8c8"
                    SeparatorsAtCenter="False"
                    TicksPaint="#232323"
                    TicksAtCenter="True"
                    MinStep="1"
                    ForceStepToMin="True"
                     
                    />
            </lvc:AxesCollection>
        </lvc:CartesianChart.XAxes>

    </lvc:CartesianChart>

</UserControl>

