<UserControl x:Class="ManagerApp.UserControls.LogInPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ManagerApp.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <DropShadowEffect x:Key="ModernShadow"
                          Color="#000000" 
                          Direction="270" 
                          ShadowDepth="8" 
                          BlurRadius="25" 
                          Opacity="0.12"/>
    </UserControl.Resources>

    <Grid Background="#F4F7FA">

        <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Center" 
                    Width="460">

            <Border Height="70"
                    Background="#3F51B5" 
                    CornerRadius="16,16,0,0"
                    Effect="{StaticResource ModernShadow}">
                <Label x:Name="label1" 
                       Content="Login Form" 
                       FontSize="26" 
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
            </Border>

            <Border Background="White" 
                    CornerRadius="0,0,16,16"
                    Padding="45,40"
                    Effect="{StaticResource ModernShadow}">

                <StackPanel>
                    <Label x:Name="label" 
                           Content="Username" 
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,0,0,8"/>

                    <Border Height="46"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Background="White"
                            Margin="0,0,0,24">
                        <TextBox x:Name="textBoxNickName" 
                                 TextWrapping="Wrap"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 FontSize="15"
                                 Foreground="#1E293B"/>
                    </Border>

                    <Label x:Name="label_Copy" 
                           Content="Password" 
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#334155"
                           Margin="0,0,0,8"/>

                    <Border Height="46"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Background="White"
                            Margin="0,0,0,35">
                        <TextBox x:Name="textBoxPassword"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 FontSize="15"
                                 Foreground="#1E293B"/>
                    </Border>

                    <Button x:Name="buttonLoin" 
                            Content="Login" 
                            Height="50"
                            Click="buttonLoin_Click"
                            Foreground="White"
                            FontSize="16"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#3F51B5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#303F9F"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#1A237E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
